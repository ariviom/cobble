# E2E test environment — points at local Supabase (`supabase start`)
#
# Copy to .env.test and fill in STRIPE_SECRET_KEY / STRIPE_WEBHOOK_SECRET:
#   cp .env.test.example .env.test
#
# Next.js loads this file when NODE_ENV=test (and skips .env.local).
# Used by: npm run e2e (Playwright sets NODE_ENV=test before starting the dev server)

# Local Supabase (default values from `supabase start`)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hdp7fsn3W0YpN81IU

# Stripe test mode — get from https://dashboard.stripe.com/test/apikeys
# For checkout E2E tests, also run: stripe listen --forward-to localhost:3001/api/stripe/webhook
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME
STRIPE_PRICE_PLUS_MONTHLY=price_REPLACE_ME
STRIPE_PRICE_PLUS_YEARLY=price_REPLACE_ME
STRIPE_CHECKOUT_SUCCESS_URL=http://localhost:3001/billing/success
STRIPE_CHECKOUT_CANCEL_URL=http://localhost:3001/sets
STRIPE_BILLING_PORTAL_RETURN_URL=http://localhost:3001/account

# External APIs (not needed for E2E — empty values prevent hitting real APIs)
REBRICKABLE_API=
BRICKLINK_CONSUMER_KEY=
BRICKLINK_CONSUMER_SECRET=
BRICKLINK_TOKEN_VALUE=
BRICLINK_TOKEN_SECRET=
